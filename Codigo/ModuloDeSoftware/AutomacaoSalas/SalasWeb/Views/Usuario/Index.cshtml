@model IEnumerable<Model.AuxModel.UsuarioAuxModel>

@{
    ViewData["Title"] = "Index";
}

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-md-12">
                                <h2 class="card-title">
                                    Usuários
                                </h2>
                                <a class="btn btn-primary" style="float:right" asp-action="Create"><i class="fas fa-plus"></i> Novo Usuário</a>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        @if (Model != null && Model.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-bordered table-striped">
                                    <thead>
                                        <tr>
                                            <th>Nome</th>
                                            <th>CPF</th>
                                            <th>Email</th>
                                            <th>Tipo</th>
                                            <th>Organização</th>
                                            <th>Status Email</th>
                                            <th>Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model)
                                        {
                                            <tr>
                                                <td>@item.UsuarioModel.Nome</td>
                                                <td>@Html.DisplayFor(modelItem => item.UsuarioModel.Cpf, "Cpf")</td>
                                                <td>@item.Email</td>
                                                <td>@item.TipoUsuarioModel.Descricao</td>
                                                <td>
                                                    @if (item.OrganizacaoModels != null && item.OrganizacaoModels.Any())
                                                    {
                                                        @string.Join(", ", item.OrganizacaoModels.Select(o => o.RazaoSocial))
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Nenhuma</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (string.IsNullOrEmpty(item.Email) || item.Email == "Não informado")
                                                    {
                                                        <span class="badge badge-secondary">Sem email</span>
                                                    }
                                                    else if (item.EmailConfirmado)
                                                    {
                                                        <span class="badge badge-success">Confirmado</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-warning">Pendente</span>
                                                    }
                                                </td>
                                                <td>
                                                    <div class="btn-group" role="group">
                                                        <a class="btn btn-primary btn-sm" asp-action="Details" asp-route-id="@item.UsuarioModel.Id">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        <a class="btn btn-info btn-sm" asp-action="Edit" asp-route-id="@item.UsuarioModel.Id">
                                                            <i class="fas fa-edit"></i>
                                                        </a>
                                                        @if (!string.IsNullOrEmpty(item.Email) && item.Email != "Não informado")
                                                        {
                                                            <button type="button" class="btn btn-secondary btn-sm" onclick="resendEmails(@item.UsuarioModel.Id)" title="Reenviar emails de ativação">
                                                                <i class="fas fa-envelope"></i>
                                                            </button>
                                                        }
                                                        <button type="button" class="btn btn-danger btn-sm" onclick="confirmDelete(@item.UsuarioModel.Id)" title="Excluir usuário">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info">
                                <h5><i class="icon fas fa-info"></i> Nenhum usuário encontrado!</h5>
                                Não há usuários cadastrados no sistema.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Formulários ocultos para ações -->
<form id="resendEmailsForm" asp-action="ResendActivationEmails" method="post" style="display: none;">
    <input type="hidden" id="resendUserId" name="userId" />
</form>

<form id="deleteForm" asp-action="Delete" method="post" style="display: none;">
    <input type="hidden" id="deleteUserId" name="id" />
    @Html.AntiForgeryToken()
</form>

@if (TempData["mensagemSucesso"] != null)
{
    <div id="mensagem-retorno" onclick="swtAlert('success','Parabéns!', '@TempData["mensagemSucesso"]')"></div>
}
else if (TempData["mensagemErro"] != null)
{
    <div id="mensagem-retorno" onclick="swtAlert('warning','Falha!', '@TempData["mensagemErro"]')"></div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@9"></script>
    <script src="~/js/sweet-alert.js"></script>

    <script>
        $(document).ready(function () {
            if (document.querySelector('#mensagem-retorno'))
                document.getElementById("mensagem-retorno").click();
        });

        function resendEmails(userId) {
            Swal.fire({
                title: 'Reenviar Emails de Ativação?',
                text: 'Isso enviará novamente os emails de confirmação e redefinição de senha para o usuário.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sim, reenviar!',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('resendUserId').value = userId;
                    document.getElementById('resendEmailsForm').submit();
                }
            });
        }

        function confirmDelete(userId) {
            Swal.fire({
                title: 'Tem certeza?',
                text: 'Esta ação não pode ser desfeita! O usuário será removido permanentemente.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sim, excluir!',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteUserId').value = userId;
                    document.getElementById('deleteForm').submit();
                }
            });
        }
    </script>
}